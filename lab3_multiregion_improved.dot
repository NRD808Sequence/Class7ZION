        legend_vpc -> legend_compute -> legend_db -> legend_lb [style=invis];
        legend_lb -> legend_security -> legend_dns -> legend_monitoring [style=invis];
        legend_monitoring -> legend_vpce -> legend_tgw -> legend_s3 [style=invis];
        legend_s3 -> legend_cf -> legend_data [style=invis];

