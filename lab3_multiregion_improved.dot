            "tokyo_aws_nat_gateway.chewbacca_nat01" [label="NAT GW\nchewbacca_nat01", shape=box, style="filled,rounded", fillcolor="#4FC3F7"];
            "tokyo_aws_eip.chewbacca_nat_eip01" [label="EIP\nnat_eip01", shape=box, style="filled,rounded", fillcolor="#4FC3F7"];
            "tokyo_aws_route_table.chewbacca_public_rt01" [label="Route Table\npublic_rt01", shape=box, style="filled,rounded", fillcolor="#4FC3F7"];
            "tokyo_aws_route_table.chewbacca_private_rt01" [label="Route Table\nprivate_rt01", shape=box, style="filled,rounded", fillcolor="#4FC3F7"];
            "tokyo_aws_route_table_association.chewbacca_public_rta01" [label="RT Assoc\npublic_rta01", shape=box, style="filled,rounded", fillcolor="#4FC3F7"];
