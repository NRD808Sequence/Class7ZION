            "tokyo_aws_lb_listener_rule.chewbacca_default_block01" [label="Listener Rule\ndefault_block01", shape=box, style="filled,rounded", fillcolor="#81C784"];
            "tokyo_aws_lb_listener_rule.chewbacca_require_origin_header01" [label="Listener Rule\nrequire_origin_hdr", shape=box, style="filled,rounded", fillcolor="#81C784"];
