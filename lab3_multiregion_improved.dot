            "tokyo_aws_route.chewbacca_private_default_route" [label="Route\nprivate_default", shape=box, style="filled,rounded", fillcolor="#4FC3F7"];
            "tokyo_aws_route.shinjuku_to_sp_route01" [label="Route\nto_sp_route01", shape=box, style="filled,rounded", fillcolor="#4FC3F7"];
        }

