digraph lab3_multiregion {
    rankdir=TB;
    fontname="Helvetica";
    fontsize=16;
    label="Lab 3: Multi-Region Terraform Infrastructure\nChewbacca (Tokyo) + Liberdade (Sao Paulo)\nkeepuneat.click";
    labelloc=t;
    node [fontname="Helvetica", fontsize=9];
    edge [fontsize=8];
    compound=true;
    newrank=true;
    splines=ortho;
    nodesep=0.4;
    ranksep=0.6;

    // ============================================================
    //  GLOBAL CLUSTER — CloudFront + CF WAF + CF Policies
    // ============================================================
    subgraph cluster_global {
        label="Global — CloudFront Edge";
        style="filled,rounded";
        fillcolor="#FFF8E1";
        color="#F57F17";
        penwidth=3;
        fontname="Helvetica-Bold";
        fontsize=12;

        "tokyo_aws_cloudfront_distribution.chewbacca_cf01" [label="CloudFront\nchewbacca_cf01", shape=hexagon, style=filled, fillcolor="#FFD54F", fontsize=9];
        "tokyo_aws_cloudfront_cache_policy.chewbacca_cache_static01" [label="CF Cache Policy\ncache_static01", shape=box, style="filled,rounded", fillcolor="#FFD54F", fontsize=9];
        "tokyo_aws_cloudfront_origin_request_policy.chewbacca_orp_static01" [label="CF Origin Req Policy\norp_static01", shape=box, style="filled,rounded", fillcolor="#FFD54F", fontsize=9];
        "tokyo_aws_cloudfront_response_headers_policy.chewbacca_rsp_static01" [label="CF Response Hdr Policy\nrsp_static01", shape=box, style="filled,rounded", fillcolor="#FFD54F", fontsize=9];
        "tokyo_aws_wafv2_web_acl.chewbacca_cf_waf01" [label="WAF WebACL\ncf_waf01", shape=box, style="filled,rounded", fillcolor="#FFF176", fontsize=9];
        "tokyo_aws_cloudwatch_log_group.chewbacca_cf_waf_logs" [label="CW Log Group\ncf_waf_logs", shape=box, style="filled,rounded", fillcolor="#4DD0E1", fontsize=9];
        "tokyo_aws_wafv2_web_acl_logging_configuration.chewbacca_cf_waf_logging" [label="WAF Logging\ncf_waf_logging", shape=box, style="filled,rounded", fillcolor="#FFF176", fontsize=9];
    }

    // ============================================================
    //  TOKYO REGION CLUSTER
    // ============================================================
    subgraph cluster_tokyo {
        label="Tokyo (ap-northeast-1) — chewbacca / shinjuku";
        style="filled,rounded";
        fillcolor="#BBDEFB";
        color="#1565C0";
        penwidth=3;
        fontname="Helvetica-Bold";
        fontsize=12;

        // --- VPC & Networking ---
        subgraph cluster_tokyo_vpc {
            label="VPC & Networking";
            style="filled,rounded";
            fillcolor="#E1F5FE";
            color="#4FC3F7";
            penwidth=1;
            fontsize=10;

            "tokyo_aws_vpc.chewbacca_vpc01" [label="VPC\nchewbacca_vpc01", shape=box, style="filled,rounded", fillcolor="#4FC3F7"];
